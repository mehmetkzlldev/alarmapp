# Mobile build-time configuration.
# These are passed to Flutter via --dart-define. NO secrets here.
# The Gemini API key lives ONLY on the backend; the app never sees it.

# Base URL of the backend API (must include scheme, host, optional port).
API_BASE_URL=https://api.example.com

# Optional: enable verbose Dio logging (true/false).
ENABLE_NETWORK_LOGS=false
