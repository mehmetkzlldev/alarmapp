# ==========================================================================
# Alarmy backend environment template.
# Copy to `.env` and fill in real values. NEVER commit a populated .env.
# ==========================================================================

# --- Runtime ---
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed origins for CORS (no trailing slash).
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Postgres ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=alarmy
DB_PASSWORD=your-db-password-here
DB_NAME=alarmy
DB_SSL=false
# Run TypeORM migrations automatically on boot (set false in prod if using CI migrations).
DB_RUN_MIGRATIONS=true
# NEVER enable synchronize in production.
DB_SYNCHRONIZE=false

# --- Redis (cache + BullMQ broker) ---
# Optionally set a full connection URL (takes precedence over the discrete fields).
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# --- JWT ---
# Generate strong random values, e.g. `openssl rand -base64 48`.
JWT_ACCESS_SECRET=your-access-secret-here-change-me
JWT_REFRESH_SECRET=your-refresh-secret-here-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Gemini (server-side ONLY; never ship to the Flutter client) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
# Optional resilience tuning (have sane code-level defaults).
GEMINI_MAX_RETRIES=2
GEMINI_BREAKER_THRESHOLD=5
GEMINI_BREAKER_COOLDOWN_MS=30000

# --- Firebase Admin (push notifications via FCM) ---
# Either point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON file,
# or supply the discrete fields below.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# Use literal \n for newlines when inlining the private key.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key\n-----END PRIVATE KEY-----\n"
# Alternative to GOOGLE_APPLICATION_CREDENTIALS: full service-account JSON inline,
# or its base64 encoding. Leave blank to use GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_B64=

# --- In-App Purchases / Subscriptions ---
# Google Play: package name + a service-account JSON (or base64) with the
# "View financial data" permission for the Android Publisher API.
ANDROID_PACKAGE_NAME=com.alarmy.app
GOOGLE_PLAY_SERVICE_ACCOUNT=
GOOGLE_PLAY_SERVICE_ACCOUNT_B64=
# Apple: App Store Connect shared secret for verifyReceipt / IAP validation.
APPLE_IAP_SHARED_SECRET=your-apple-shared-secret-here
# Store product identifiers (must match the store configuration).
IAP_APPLE_MONTHLY_ID=com.alarmy.premium.monthly
IAP_APPLE_YEARLY_ID=com.alarmy.premium.yearly
IAP_GOOGLE_MONTHLY_ID=premium_monthly
IAP_GOOGLE_YEARLY_ID=premium_yearly

# --- AWS S3 (object-detection image uploads, private bucket) ---
AWS_REGION=us-east-1
S3_BUCKET=alarmy-object-detection
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# TTL (seconds) for presigned upload/download URLs.
S3_PRESIGN_TTL=300

# --- Throttling (global rate limit) ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# --- Business rules ---
# Free-tier alarm limit; alarms beyond this require an active subscription.
FREE_ALARM_LIMIT=3
